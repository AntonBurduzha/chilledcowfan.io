---
import Layout from '~/layouts/Layout.astro';
import { getSortedPosts } from '~/utils';
import { getCollection, render } from 'astro:content';
import PostPreview from '~/components/PostPreview.astro';
import Pagination from '~/components/Pagination.astro';
import BlockHeader from '~/components/BlockHeader.astro';
import HomeBanner from '~/components/HomeBanner.astro';
import siteConfig from '~/site.config';

const home = await getCollection('home');
let HomeContent;
let homeAvatarImage;
let githubUserName;
let gitlabUserName;
if (home.length > 0) {
  const homeEntry = home[0];
  const { Content } = await render(homeEntry);
  HomeContent = Content;
  homeAvatarImage = homeEntry.data.avatarImage;
  githubUserName = homeEntry.data.githubUserName;
  gitlabUserName = homeEntry.data.gitlabUserName;
}
const sortedPosts = await getSortedPosts();
---

<Layout>
  {
    HomeContent && (
      <HomeBanner
        avatarImage={homeAvatarImage}
        githubUserName={githubUserName}
        gitlabUserName={gitlabUserName}
      >
        <HomeContent />
      </HomeBanner>
    )
  }
  {
    sortedPosts.length > 0 && (
      <section>
        <BlockHeader>Latest Posts</BlockHeader>
        {sortedPosts
          .reverse()
          .slice(0, Math.floor(siteConfig.pageSize / 2))
          .map((post) => (
            <PostPreview post={post} />
          ))}
        <Pagination nextLink="/posts" nextText="Older posts" />
      </section>
    )
  }
</Layout>

<style is:global>
  a.heading-anchor {
    display: none !important;
  }
</style>
