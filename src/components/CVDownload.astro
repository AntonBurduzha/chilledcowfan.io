---
import fs from 'node:fs';
import IconCV from '~/icons/cv.svg';

const cvExists = fs.existsSync('public/Anton_Burduzha_CV.pdf');
---

{
  cvExists && (
    <a
      href="/Anton_Burduzha_CV.pdf"
      download="Anton_Burduzha_CV.pdf"
      class="block"
      aria-label="Download CV"
    >
      <IconCV class="size-6 text-accent" />
    </a>
  )
}
